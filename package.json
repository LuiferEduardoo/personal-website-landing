{
  "name": "personal-website-landing",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--dns-result-order=ipv4first' astro dev",
    "build": "NODE_OPTIONS='--dns-result-order=ipv4first' astro build",
    "preview": "astro preview",
    "astro": "astro",
    "preview:cf": "astro build && npx wrangler dev --config dist/server/wrangler.json",
    "deploy": "astro build && npx wrangler deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.1",
    "astro": "^6.1.7"
  }
}
