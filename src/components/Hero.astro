---
import Carousel from "./Carousel.astro";

const slides = [
  { src: "https://cdn.luifereduardoo.com/img/about/hero-1.webp", alt: "" },
  { src: "https://cdn.luifereduardoo.com/img/about/hero-2.webp", alt: "" },
  { src: "https://cdn.luifereduardoo.com/img/about/hero-3.webp", alt: "" },
];
---

<section class="hero" aria-label="Presentación">
  <div class="hero-bg" aria-hidden="true">
    <Carousel slides={slides} label="Imágenes destacadas" />
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content">
    <p class="hero-role">Desarrollador de Software</p>
    <h1 class="hero-name">Luifer Ortega</h1>
    <div class="hero-actions">
      <a href="#proyectos" class="btn btn-primary">Ver proyectos</a>
      <a href="#sobre-mi" class="btn btn-secondary">Sobre mí</a>
    </div>
    <a
      class="hero-github"
      href="https://github.com/LuiferEduardoo"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Perfil de GitHub de Luifer Ortega"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" width="28" height="28">
        <path
          fill="currentColor"
          d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.34-1.27-1.7-1.27-1.7-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.35.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.17a10.95 10.95 0 0 1 5.76 0c2.2-1.48 3.16-1.17 3.16-1.17.63 1.58.24 2.75.12 3.04.73.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.26 5.64.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.14 0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z"
        ></path>
      </svg>
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    padding-top: var(--header-height);
    display: grid;
    place-items: center;
    overflow: hidden;
    isolation: isolate;
    color: #fff;
  }

  .hero-bg,
  .hero-overlay {
    position: absolute;
    inset: var(--header-height) 0 0 0;
  }

  .hero-overlay {
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: clamp(1rem, 4vw, 2rem);
    max-width: 60rem;
  }

  .hero-role {
    margin: 0 0 0.75rem;
    font-size: clamp(0.875rem, 1.5vw, 1.125rem);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.9;
  }

  .hero-name {
    margin: 0 0 1.75rem;
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    text-wrap: balance;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border: 1px solid transparent;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    transition:
      background-color var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: #fff;
  }

  .btn-primary:hover {
    background-color: color-mix(in srgb, var(--color-accent) 85%, white);
  }

  .btn-secondary {
    background-color: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.12);
    border-color: #fff;
  }

  .hero-github {
    display: inline-flex;
    color: #fff;
    opacity: 0.85;
    transition:
      opacity var(--transition),
      transform var(--transition);
  }

  .hero-github:hover {
    opacity: 1;
    transform: scale(1.1);
  }
</style>
