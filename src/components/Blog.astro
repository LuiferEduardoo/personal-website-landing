---
import {
  fetchBlogPosts,
  normalizeUrl,
  parseReadingMinutes,
  stripHtml,
} from "../lib/api";

const posts = await fetchBlogPosts(3);
const hasPosts = posts.length > 0;

const MONTHS_ES = [
  "Ene.",
  "Feb.",
  "Mar.",
  "Abr.",
  "May.",
  "Jun.",
  "Jul.",
  "Ago.",
  "Sep.",
  "Oct.",
  "Nov.",
  "Dic.",
];

function formatAbsolute(iso: string): string {
  const d = new Date(iso);
  return `${d.getDate()} ${MONTHS_ES[d.getMonth()]} ${d.getFullYear()}`;
}
---

<section id="blog" class="blog" aria-labelledby="blog-heading">
  <h2 id="blog-heading" class="blog-heading">Blog</h2>

  {
    hasPosts ? (
      <div class="blog-grid">
        {posts.map((post, i) => {
          const minutes = parseReadingMinutes(post.reading_time);
          const excerpt = stripHtml(post.content);
          return (
            <article class="post">
              <a
                class="post-link"
                href={`/blog/${post.link}`}
                aria-label={`Leer: ${post.title}`}
              >
                <div class="post-image">
                  {post.cover_image?.url && (
                    <img
                      src={normalizeUrl(post.cover_image.url)}
                      alt={post.cover_image.name ?? ""}
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  )}
                </div>
                <div class="post-body">
                  <h3 class="post-title">{post.title}</h3>
                  <p class="post-excerpt">{excerpt}</p>
                  <div class="post-meta">
                    <time datetime={post.created_at} data-relative>
                      {formatAbsolute(post.created_at)}
                    </time>
                    {minutes > 0 && (
                      <>
                        <span class="dot" aria-hidden="true">
                          ·
                        </span>
                        <span class="reading">{minutes} min</span>
                      </>
                    )}
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <p class="blog-empty">Pronto habrá publicaciones aquí.</p>
    )
  }
</section>

<style>
  .blog {
    --blog-bg: #f5f5f7;
    --blog-text: #111111;
    --blog-muted: #555555;
    --blog-border: rgba(0, 0, 0, 0.1);
    --blog-surface: #ffffff;
    --blog-image-bg: rgba(0, 0, 0, 0.04);
    --blog-shadow: 0 12px 30px -18px rgba(0, 0, 0, 0.25);
    --blog-shadow-hover: 0 20px 40px -20px rgba(0, 0, 0, 0.35);

    padding: clamp(3rem, 6vw, 4.5rem) clamp(1rem, 4vw, 2rem);
    background-color: var(--blog-bg);
    color: var(--blog-text);
    transition:
      background-color var(--transition),
      color var(--transition);
  }

  :global(:root[data-theme="dark"]) .blog {
    --blog-bg: #0d1117;
    --blog-text: #e6edf3;
    --blog-muted: #9aa5b1;
    --blog-border: rgba(255, 255, 255, 0.08);
    --blog-surface: rgba(255, 255, 255, 0.02);
    --blog-image-bg: rgba(255, 255, 255, 0.04);
    --blog-shadow: 0 12px 30px -18px rgba(0, 0, 0, 0.6);
    --blog-shadow-hover: 0 20px 40px -20px rgba(0, 0, 0, 0.8);
  }

  .blog-heading {
    max-width: 72rem;
    margin: 0 auto clamp(1.5rem, 4vw, 2.5rem);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2rem);
    max-width: 72rem;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .post {
    border: 1px solid var(--blog-border);
    border-radius: 1rem;
    overflow: hidden;
    background-color: var(--blog-surface);
    box-shadow: var(--blog-shadow);
    transition:
      transform var(--transition),
      box-shadow var(--transition),
      border-color var(--transition);
  }

  .post:hover {
    transform: translateY(-4px);
    box-shadow: var(--blog-shadow-hover);
  }

  .post-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .post-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  .post-image {
    aspect-ratio: 16 / 10;
    background-color: var(--blog-image-bg);
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease;
  }

  .post:hover .post-image img {
    transform: scale(1.04);
  }

  .post-body {
    padding: clamp(1rem, 2.5vw, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-title {
    margin: 0;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 700;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-excerpt {
    margin: 0;
    color: var(--blog-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    color: var(--blog-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .post-meta .reading {
    font-weight: 600;
  }

  .blog-empty {
    max-width: 72rem;
    margin: 0 auto;
    color: var(--blog-muted);
    text-align: center;
  }
</style>

<script>
  const formatRelative = (iso: string): string | null => {
    const diffMs = Date.now() - new Date(iso).getTime();
    if (diffMs < 0) return null;

    const diffMin = Math.floor(diffMs / 60000);
    if (diffMin < 1) return "hace un momento";
    if (diffMin < 60)
      return `hace ${diffMin} ${diffMin === 1 ? "minuto" : "minutos"}`;

    const diffHour = Math.floor(diffMin / 60);
    if (diffHour < 24)
      return `hace ${diffHour} ${diffHour === 1 ? "hora" : "horas"}`;

    const diffDay = Math.floor(diffHour / 24);
    if (diffDay < 7)
      return `hace ${diffDay} ${diffDay === 1 ? "día" : "días"}`;

    if (diffDay < 30) {
      const diffWeek = Math.floor(diffDay / 7);
      return `hace ${diffWeek} ${diffWeek === 1 ? "semana" : "semanas"}`;
    }

    return null;
  };

  document
    .querySelectorAll<HTMLTimeElement>("time[data-relative]")
    .forEach((el) => {
      const iso = el.getAttribute("datetime");
      if (!iso) return;
      const relative = formatRelative(iso);
      if (relative) el.textContent = relative;
    });
</script>
