---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import ReadingProgress from "../../components/ReadingProgress.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import Footer from "../../components/Footer.astro";
import {
  fetchBlogPosts,
  normalizeUrl,
  parseReadingMinutes,
  stripHtml,
  type BlogPostRead,
} from "../../lib/api";

export async function getStaticPaths() {
  const posts = await fetchBlogPosts(100);
  return posts.map((post) => ({
    params: { link: post.link },
    props: { post },
  }));
}

interface Props {
  post: BlogPostRead;
}

const { post } = Astro.props;

const MONTHS_ES = [
  "Ene.",
  "Feb.",
  "Mar.",
  "Abr.",
  "May.",
  "Jun.",
  "Jul.",
  "Ago.",
  "Sep.",
  "Oct.",
  "Nov.",
  "Dic.",
];

const formatAbsolute = (iso: string): string => {
  const d = new Date(iso);
  return `${d.getDate()} ${MONTHS_ES[d.getMonth()]} ${d.getFullYear()}`;
};

const minutes = parseReadingMinutes(post.reading_time);
const description = stripHtml(post.content).slice(0, 160);
---

<BaseLayout title={`${post.title} — Luifer Ortega`} description={description}>
  <SiteHeader />
  <ReadingProgress />

  <main class="blog-page">
    <article class="post">
      {
        post.cover_image?.url && (
          <div class="post-cover">
            <img
              src={normalizeUrl(post.cover_image.url)}
              alt={post.cover_image.name ?? post.title}
              loading="eager"
              decoding="async"
            />
          </div>
        )
      }

      <div class="post-content">
        <a class="back" href="/#blog">← Volver al blog</a>

        <h1 class="post-title">{post.title}</h1>

        <div class="post-meta">
          <time datetime={post.created_at} data-relative>
            {formatAbsolute(post.created_at)}
          </time>
          {
            minutes > 0 && (
              <>
                <span aria-hidden="true">·</span>
                <span class="reading">{minutes} min</span>
              </>
            )
          }
          {
            post.user?.name && (
              <>
                <span aria-hidden="true">·</span>
                <span>por {post.user.name}</span>
              </>
            )
          }
        </div>

        <div class="post-body" set:html={post.content} />

        <div class="post-share">
          <ShareButtons title={post.title} />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-page {
    padding-top: var(--header-height);
  }

  .post {
    max-width: 48rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2rem)
      clamp(3rem, 6vw, 4.5rem);
  }

  .post-cover {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-radius: 1rem;
    overflow: hidden;
    background-color: var(--color-surface);
    aspect-ratio: 16 / 9;
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .back {
    align-self: flex-start;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition);
  }
  .back:hover {
    color: var(--color-accent);
  }

  .post-title {
    margin: 0;
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    text-wrap: balance;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .post-meta .reading {
    font-weight: 600;
  }

  .post-body {
    margin-top: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .post-body :global(p) {
    margin: 0 0 1em;
  }
  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    margin: 1.5em 0 0.5em;
    font-weight: 700;
    line-height: 1.25;
  }
  .post-body :global(h2) {
    font-size: 1.5rem;
  }
  .post-body :global(h3) {
    font-size: 1.25rem;
  }
  .post-body :global(a) {
    color: var(--color-accent);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1em;
    padding-left: 1.5rem;
  }
  .post-body :global(li) {
    margin: 0.25em 0;
  }
  .post-body :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 1em 0;
  }
  .post-body :global(pre) {
    padding: 1rem;
    border-radius: var(--radius);
    background-color: var(--color-surface);
    overflow-x: auto;
  }
  .post-body :global(code) {
    font-family: ui-monospace, "SFMono-Regular", "Menlo", "Consolas", monospace;
    font-size: 0.9em;
  }
  .post-body :global(blockquote) {
    margin: 1em 0;
    padding-left: 1rem;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .post-share {
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid var(--color-border);
  }
</style>

<script>
  const formatRelative = (iso: string): string | null => {
    const diffMs = Date.now() - new Date(iso).getTime();
    if (diffMs < 0) return null;

    const diffMin = Math.floor(diffMs / 60000);
    if (diffMin < 1) return "hace un momento";
    if (diffMin < 60)
      return `hace ${diffMin} ${diffMin === 1 ? "minuto" : "minutos"}`;

    const diffHour = Math.floor(diffMin / 60);
    if (diffHour < 24)
      return `hace ${diffHour} ${diffHour === 1 ? "hora" : "horas"}`;

    const diffDay = Math.floor(diffHour / 24);
    if (diffDay < 7)
      return `hace ${diffDay} ${diffDay === 1 ? "día" : "días"}`;

    if (diffDay < 30) {
      const diffWeek = Math.floor(diffDay / 7);
      return `hace ${diffWeek} ${diffWeek === 1 ? "semana" : "semanas"}`;
    }

    return null;
  };

  document
    .querySelectorAll<HTMLTimeElement>("time[data-relative]")
    .forEach((el) => {
      const iso = el.getAttribute("datetime");
      if (!iso) return;
      const relative = formatRelative(iso);
      if (relative) el.textContent = relative;
    });
</script>
