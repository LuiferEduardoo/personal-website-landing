---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Footer from "../../components/Footer.astro";
import { fetchProjectByLink, normalizeUrl } from "../../lib/api";

const { link } = Astro.params;
const project = link ? await fetchProjectByLink(link) : null;

if (!project) {
  return new Response(null, { status: 404 });
}

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=300, stale-while-revalidate=3600",
);
---

<BaseLayout
  title={`${project.name} — Luifer Ortega`}
  description={project.brief_description}
>
  <SiteHeader />

  <main class="project-page">
    <article class="project">
      {
        project.image?.url && (
          <div class="project-image-wrap">
            <img
              class="project-image"
              src={normalizeUrl(project.image.url)}
              alt={project.name}
              loading="eager"
              decoding="async"
            />
          </div>
        )
      }

      <div class="project-content">
        <a class="back" href="/#proyectos">← Volver a proyectos</a>

        <h1 class="project-title">{project.name}</h1>
        <p class="project-brief">{project.brief_description}</p>

        {
          project.url_project && (
            <a
              class="project-visit"
              href={project.url_project}
              target="_blank"
              rel="noopener noreferrer"
            >
              Visitar proyecto →
            </a>
          )
        }

        <div class="project-description" set:html={project.description} />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .project-page {
    padding-top: var(--header-height);
  }

  .project {
    max-width: 60rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2rem)
      clamp(3rem, 6vw, 4.5rem);
  }

  .project-image-wrap {
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-radius: 1rem;
    overflow: hidden;
    background-color: var(--color-surface);
    aspect-ratio: 16 / 9;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .back {
    align-self: flex-start;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition);
  }
  .back:hover {
    color: var(--color-accent);
  }

  .project-title {
    margin: 0;
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    text-wrap: balance;
  }

  .project-brief {
    margin: 0;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
  }

  .project-visit {
    align-self: flex-start;
    padding: 0.625rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    transition:
      border-color var(--transition),
      color var(--transition),
      background-color var(--transition);
  }
  .project-visit:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .project-description {
    margin-top: 1rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .project-description :global(p) {
    margin: 0 0 1em;
  }
  .project-description :global(h1),
  .project-description :global(h2),
  .project-description :global(h3),
  .project-description :global(h4) {
    margin: 1.5em 0 0.5em;
    font-weight: 700;
    line-height: 1.25;
  }
  .project-description :global(h2) {
    font-size: 1.5rem;
  }
  .project-description :global(h3) {
    font-size: 1.25rem;
  }
  .project-description :global(a) {
    color: var(--color-accent);
  }
  .project-description :global(ul),
  .project-description :global(ol) {
    margin: 0 0 1em;
    padding-left: 1.5rem;
  }
  .project-description :global(li) {
    margin: 0.25em 0;
  }
  .project-description :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    margin: 1em 0;
  }
  .project-description :global(pre) {
    padding: 1rem;
    border-radius: var(--radius);
    background-color: var(--color-surface);
    overflow-x: auto;
  }
  .project-description :global(code) {
    font-family: ui-monospace, "SFMono-Regular", "Menlo", "Consolas", monospace;
    font-size: 0.9em;
  }
  .project-description :global(blockquote) {
    margin: 1em 0;
    padding-left: 1rem;
    border-left: 3px solid var(--color-border);
    color: var(--color-text-muted);
  }
</style>
